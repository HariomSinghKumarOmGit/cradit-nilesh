{
  "version": 2,
  "name": "sentinoid-eco",
  "rewrites": [
    { "source": "/get-local-ip", "destination": "/api/get-local-ip" },
    { "source": "/api/security-status", "destination": "/api/security-status" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
